{
  "name": "flux-training",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.16.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "bootstrap:real-runtime-prereqs": "node scripts/bootstrap-real-runtime-prereqs.mjs",
    "test:bootstrap-real-runtime-prereqs": "node --test scripts/bootstrap-real-runtime-prereqs.test.mjs",
    "test:real-runtime-prereqs": "node --test scripts/check-real-runtime-prereqs.test.mjs",
    "test:real-login-smoke": "node --test scripts/run-real-login-smoke.test.mjs",
    "test:real-cloud-connectivity-smoke": "node --test scripts/run-real-cloud-connectivity-smoke.test.mjs",
    "test:real-runtime-doctor": "node --test scripts/doctor-real-runtime.test.mjs",
    "test:provider-auth-readiness": "node --test scripts/check-provider-auth-readiness.test.mjs",
    "test:provider-auth-sources": "node --test scripts/check-provider-auth-sources.test.mjs",
    "test:cloud-project-access": "node --test scripts/check-cloud-project-access.test.mjs",
    "test:cloud-functions-deployment": "node --test scripts/check-cloud-functions-deployment.test.mjs",
    "test:cloud-billing-readiness": "node --test scripts/check-cloud-billing-readiness.test.mjs",
    "test:firebase-deploy-config": "node --test scripts/check-firebase-deploy-config.test.mjs",
    "smoke:real-login": "node scripts/run-real-login-smoke.mjs",
    "smoke:real-cloud-connectivity": "node scripts/run-real-cloud-connectivity-smoke.mjs",
    "doctor:real-runtime": "node scripts/doctor-real-runtime.mjs",
    "check:provider-auth-readiness": "node scripts/check-provider-auth-readiness.mjs",
    "check:provider-auth-sources": "node scripts/check-provider-auth-sources.mjs",
    "check:cloud-project-access": "node scripts/check-cloud-project-access.mjs",
    "check:cloud-functions-deployment": "node scripts/check-cloud-functions-deployment.mjs",
    "check:cloud-billing-readiness": "node scripts/check-cloud-billing-readiness.mjs",
    "check:firebase-deploy-config": "node scripts/check-firebase-deploy-config.mjs",
    "test:critical": "pnpm --filter @flux/backend test -- src/application/critical-regression-suite.spec.ts && pnpm --filter @flux/web test -- src/application/critical-regression-suite.spec.ts && cd apps/ios && swift test --filter CriticalRegressionFlowTests",
    "test:happy-paths": "pnpm --filter @flux/backend test -- src/application/happy-path-e2e-suite.spec.ts && pnpm --filter @flux/web test -- src/application/happy-path-e2e-suite.spec.ts && cd apps/ios && swift test --filter HappyPathFlowTests",
    "test:edge-cases": "pnpm --filter @flux/backend test -- src/application/edge-case-e2e-suite.spec.ts && pnpm --filter @flux/web test -- src/application/edge-case-e2e-suite.spec.ts && cd apps/ios && swift test --filter EdgeCaseFlowTests",
    "test:recovery-paths": "pnpm --filter @flux/backend test -- src/application/recovery-path-e2e-suite.spec.ts && pnpm --filter @flux/web test -- src/application/recovery-path-e2e-suite.spec.ts && cd apps/ios && swift test --filter RecoveryPathFlowTests",
    "release:check": "pnpm check && pnpm test && pnpm test:critical && cd apps/ios && swift test",
    "check": "pnpm -r check",
    "check:real-runtime-prereqs": "node scripts/check-real-runtime-prereqs.mjs",
    "deploy:functions:cloud": "npx firebase-tools deploy --only functions:backend --project flux-training-mvp",
    "dev:web": "VITE_WEB_RUNTIME_MODE=product VITE_WEB_QA_UI_ENABLED=0 pnpm --filter @flux/web dev",
    "dev:web:product": "VITE_API_TARGET=${VITE_API_TARGET:-https://us-central1-flux-training-mvp.cloudfunctions.net} VITE_WEB_RUNTIME_MODE=product VITE_WEB_QA_UI_ENABLED=0 pnpm --filter @flux/web dev",
    "dev:web:qa": "pnpm --filter @flux/web dev:qa",
    "dev:backend": "pnpm --filter @flux/backend dev",
    "dev:backend:demo": "pnpm --filter @flux/backend start:demo"
  },
  "devDependencies": {
    "@fission-ai/openspec": "1.2.0",
    "pumuki": "6.3.55"
  }
}
